{
    "context": {
        "fileName": [
            "GEMINI.md"
        ]
    },
    "mcpServers": {
        "gcloud": {
            "command": "npx",
            "args": [
                "-y",
                "@google-cloud/gcloud-mcp"
            ]
        },
        "claude-context": {
            "command": "npx",
            "args": [
                "-y",
                "@zilliz/claude-context-mcp@latest"
            ],
            "trust": true
        },
        "dart": {
            "command": "C:\\Users\\xursc\\projects\\calorix\\.fvm\\versions\\3.41.9\\bin\\cache\\dart-sdk\\bin\\dart.exe",
            "args": [
                "mcp-server",
                "--force-roots-fallback"
            ],
            "cwd": "C:\\Users\\xursc\\projects\\calorix",
            "timeout": 30000,
            "trust": false
        }
    },
    "mcp": {
        "allowed": [
            "dart",
            "gcloud",
            "firebase",
            "claude-context",
            "context7",
            "context-mode"
        ]
    }
}