              "coordinateSpace": "roiNormalized"
            },
            {
              "id": "kcal-left-pill",
              "label": "Calories remaining pill",
              "box": { "x": 0.25, "y": 0.63, "width": 0.50, "height": 0.10 },
              "coordinateSpace": "roiNormalized"
            }
          ]
        },
        {
          "id": "macro-rows",
          "label": "Macro Progress Rows",
          "type": "component",
          "box": { "x": 0.01, "y": 0.39, "width": 0.98, "height": 0.12 },
