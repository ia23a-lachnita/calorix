{
  "screens": {
    "today": {
      "platform": "android",
      "expectedImage": "docs/mockups/image/dark/single/Today.png",
      "outputDir": ".ui-diff/today",
      "pixelmatchThreshold": 0.1,
      "maxDiffPercent": 0.14,
      "maxRegions": 20,
      "maxVlmRegions": 4,
      "includeVlmAnalysis": true,
      "vlmPolicy": "required",
      "requireVlmAnalysis": true,
      "preCapture": [
        {
          "type": "adbShell",
          "command": "am start -a android.intent.action.VIEW -d calorix://debug/reseed com.calorix.calorix/.MainActivity",
          "description": "Trigger debug reseed deep link to seed mockup-matching data"
        },
        {
          "type": "adbShell",
          "command": "sleep 5",
          "description": "Wait for Firestore reseed and navigation to Today to complete"
        }
      ],
      "ignoreRegions": [
        {
          "x": 0, "y": 0, "width": 1080, "height": 80,
          "reason": "status bar", "type": "system", "coordinateSpace": "actual"
        },
        {
          "x": 0, "y": 2268, "width": 1080, "height": 132,
          "reason": "navigation bar and bottom chrome", "type": "system", "coordinateSpace": "actual"
        }
      ],
      "regionsOfInterest": [
        {
          "id": "macro-ring-hero",
          "label": "Macro Ring Hero Card",
          "type": "component",
          "box": { "x": 0.01, "y": 0.05, "width": 0.98, "height": 0.34 },
          "coordinateSpace": "normalized",
          "maxDiffPercent": 0.15,
          "allowedDynamicSubregions": [
            {
              "id": "kcal-number",
              "label": "Calorie count center text",
              "box": { "x": 0.33, "y": 0.35, "width": 0.34, "height": 0.15 },
              "coordinateSpace": "roiNormalized"
            },
            {
              "id": "target-kcal-text",
