function Frame({ children, dark = false }) {
  return (
    <IOSDevice width={402} height={874} dark={dark}>
      {children}
    </IOSDevice>
  );
}

// One global mode controls light/dark across every theme-aware screen.
// Camera + processing + lock-screen artboards stay dark by design (they are
// camera/system surfaces); everything else follows `mode`.
const DEFAULTS = /*EDITMODE-BEGIN*/{
  "mode": "light",
  "scanState": "idle",
  "foodEdit": false,
  "historyView": "week",
  "goalsPeriod": "idle"
}/*EDITMODE-END*/;

function App() {
  const [tw, setTweak] = useTweaks(DEFAULTS);
  const dark = tw.mode === 'dark';

  return (
    <>
      <DesignCanvas>
        <DCSection id="brand" title="Calorix" subtitle="A faster, free alternative — camera-first calorie tracking. Atelier-athletic system.">
          <DCArtboard id="brand-card" label="Identity" width={402} height={874}>
            <BrandCard mode={tw.mode}/>
          </DCArtboard>
        </DCSection>

        <DCSection id="capture" title="Camera & capture flow" subtitle="Default landing screen. Open app → frame → tap → cloud → push notification.">
          <DCArtboard id="scan" label="01 · Scan · idle / capturing" width={402} height={874}>
            <Frame dark={dark}><CXScanScreen state={tw.scanState} mode={tw.mode}/></Frame>
          </DCArtboard>
          <DCArtboard id="processing" label="02 · Processing card" width={402} height={874}>
            <Frame dark={dark}><CXProcessingScreen mode={tw.mode}/></Frame>
          </DCArtboard>
          <DCArtboard id="lock-notif" label="03 · Lock-screen push" width={402} height={874}>
            <Frame dark><CXLockScreen/></Frame>
          </DCArtboard>
        </DCSection>

        <DCSection id="today" title="Today dashboard" subtitle="Hero macro ring on top of a card, then macro sub-cards. Entry animation fills + counts up.">
          <DCArtboard id="today" label="Today" width={402} height={874}>
            <Frame dark={dark}><CXTodayScreen mode={tw.mode}/></Frame>
          </DCArtboard>
        </DCSection>

        <DCSection id="food" title="Food detail · edit · CRUD" subtitle="Hero, editable nutrition, detected items, AI fix. Toggle original / edit state.">
          <DCArtboard id="food" label={`Food detail · ${tw.foodEdit ? 'editing' : 'original'}`} width={402} height={874}>
            <Frame dark={dark}><CXFoodDetailScreen mode={tw.mode} editing={tw.foodEdit}/></Frame>
          </DCArtboard>
        </DCSection>

        <DCSection id="long" title="History & Goals" subtitle="Long-term progress and a motivational, data-driven plan.">
          <DCArtboard id="history" label={`History · ${tw.historyView}`} width={402} height={874}>
            <Frame dark={dark}><CXHistoryScreen mode={tw.mode} view={tw.historyView}/></Frame>
          </DCArtboard>
          <DCArtboard id="goals" label={`Goals · ${tw.goalsPeriod === 'select' ? 'period select' : 'idle'}`} width={402} height={874}>
            <Frame dark={dark}><CXGoalsScreen mode={tw.mode} period={tw.goalsPeriod}/></Frame>
          </DCArtboard>
        </DCSection>

        <DCSection id="ai" title="Calorix AI" subtitle="Integrated assistant that can edit your meals and macro plan with confirmation.">
          <DCArtboard id="ai" label="AI chat" width={402} height={874}>
            <Frame dark={dark}><CXAIScreen mode={tw.mode}/></Frame>
          </DCArtboard>
        </DCSection>

        <DCSection id="spec" title="Spec · Implementation Notes" subtitle="One annotation card per screen. Each element is named, described, and spec'd for no-ambiguity Flutter implementation.">
          <DCArtboard id="spec-scan"       label="Spec · Scan"        width={460} height={874}><CXScanSpec       mode={tw.mode}/></DCArtboard>
          <DCArtboard id="spec-processing" label="Spec · Processing"  width={460} height={874}><CXProcessingSpec mode={tw.mode}/></DCArtboard>
          <DCArtboard id="spec-today"      label="Spec · Today"       width={460} height={874}><CXTodaySpec      mode={tw.mode}/></DCArtboard>
          <DCArtboard id="spec-food"       label="Spec · Food detail" width={460} height={874}><CXFoodSpec       mode={tw.mode}/></DCArtboard>
          <DCArtboard id="spec-history"    label="Spec · History"     width={460} height={874}><CXHistorySpec    mode={tw.mode}/></DCArtboard>
          <DCArtboard id="spec-goals"      label="Spec · Goals"       width={460} height={874}><CXGoalsSpec      mode={tw.mode}/></DCArtboard>
          <DCArtboard id="spec-ai"         label="Spec · AI"          width={460} height={874}><CXAISpec         mode={tw.mode}/></DCArtboard>
        </DCSection>
      </DesignCanvas>

      <TweaksPanel title="Tweaks">
        <TweakSection label="Theme">
          <TweakRadio
            label="App mode"
            value={tw.mode}
            onChange={(v) => setTweak('mode', v)}
            options={[
              { value: 'light', label: 'Light' },
              { value: 'dark',  label: 'Dark' },
            ]}
          />
        </TweakSection>
        <TweakSection label="Camera">
          <TweakRadio
            label="Scan state"
            value={tw.scanState}
            onChange={(v) => setTweak('scanState', v)}
            options={[
              { value: 'idle',      label: 'Idle' },
              { value: 'capturing', label: 'Capture' },
            ]}
          />
        </TweakSection>
        <TweakSection label="Food detail">
          <TweakRadio
            label="State"
            value={tw.foodEdit ? 'edit' : 'original'}
            onChange={(v) => setTweak('foodEdit', v === 'edit')}
            options={[
              { value: 'original', label: 'Original' },
              { value: 'edit',     label: 'Editing' },
            ]}
          />
        </TweakSection>
        <TweakSection label="History">
          <TweakRadio
            label="Calendar view"
            value={tw.historyView}
            onChange={(v) => setTweak('historyView', v)}
            options={[
              { value: 'week',  label: 'Week' },
              { value: 'month', label: 'Month' },
            ]}
          />
        </TweakSection>
        <TweakSection label="Goals">
          <TweakRadio
            label="Period selector"
            value={tw.goalsPeriod}
            onChange={(v) => setTweak('goalsPeriod', v)}
            options={[
              { value: 'idle',   label: 'Idle' },
              { value: 'select', label: 'Selecting' },
            ]}
          />
        </TweakSection>
      </TweaksPanel>
    </>
  );
}

// Brand identity card — supports light + dark.
