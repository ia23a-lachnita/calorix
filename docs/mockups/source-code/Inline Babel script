  const ink3 = dark ? 'rgba(242,243,245,0.45)' : 'rgba(11,13,16,0.40)';
  const tileBg = dark ? 'rgba(255,255,255,0.04)' : '#FFFFFF';
  const tileBorder = dark ? 'rgba(255,255,255,0.08)' : 'rgba(11,13,16,0.06)';

  return (
    <div style={{
      width: '100%', height: '100%',
      background: bg, color: ink,
      fontFamily: CX_FONT,
      padding: '54px 24px 100px',
      display: 'flex', flexDirection: 'column', position: 'relative', overflow: 'hidden',
    }}>
      <div style={{
        position: 'absolute', right: -120, top: -120, width: 380, height: 380, borderRadius: 999,
        background: dark
          ? 'radial-gradient(closest-side, rgba(25,211,217,0.22), transparent)'
          : 'radial-gradient(closest-side, rgba(25,211,217,0.32), transparent)',
        filter: 'blur(20px)',
      }}/>
      <div style={{
        position: 'absolute', left: -120, bottom: 120, width: 320, height: 320, borderRadius: 999,
        background: dark
          ? 'radial-gradient(closest-side, rgba(58,91,255,0.18), transparent)'
          : 'radial-gradient(closest-side, rgba(58,91,255,0.20), transparent)',
        filter: 'blur(20px)',
      }}/>

      <div style={{ position: 'relative', zIndex: 2 }}>
        <CXLabel color={ink2}>Mobile · iOS · Flutter-ready</CXLabel>
        <div style={{ marginTop: 18, display: 'flex', alignItems: 'center', gap: 14 }}>
          <div style={{
            width: 64, height: 64, borderRadius: 18,
            background: CX.gradAI,
            display: 'flex', alignItems: 'center', justifyContent: 'center',
            boxShadow: '0 12px 30px rgba(25,211,217,0.30), inset 0 0 0 1px rgba(255,255,255,0.18)',
          }}>
            <CXLogo size={38} color="#0B0D10"/>
          </div>
          <div>
            <div style={{ fontSize: 44, fontWeight: 600, letterSpacing: '-0.05em', lineHeight: 1 }}>Calorix</div>
            <div style={{ fontFamily: CX_MONO, fontSize: 11, marginTop: 6, color: ink2, letterSpacing: '0.18em', textTransform: 'uppercase' }}>
              Snap · Track · Stay on target
