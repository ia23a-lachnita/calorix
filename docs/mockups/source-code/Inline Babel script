        </div>

        <div style={{ marginTop: 36, fontSize: 18, lineHeight: 1.45, letterSpacing: '-0.01em', maxWidth: 320 }}>
          Open the app. The camera is already on.<br/>
          One tap. We process in the cloud. A push tells you when it's logged.
        </div>
      </div>

      <div style={{ marginTop: 'auto', position: 'relative', zIndex: 2 }}>
        <CXLabel color={ink3} style={{ marginBottom: 10 }}>Macro palette</CXLabel>
        <div style={{ display: 'flex', gap: 10 }}>
          {[
            { c: CX.blue,  l: 'PROTEIN' },
            { c: CX.cyan,  l: 'CARBS'   },
            { c: CX.green, l: 'FAT'     },
          ].map((s) => (
            <div key={s.l} style={{
              flex: 1, padding: 12, borderRadius: 14,
              background: tileBg,
              border: `0.5px solid ${tileBorder}`,
            }}>
              <div style={{ width: 24, height: 24, borderRadius: 8, background: s.c }}/>
              <div style={{
                fontFamily: CX_MONO, fontSize: 9.5, color: ink2,
                letterSpacing: '0.14em', marginTop: 8,
              }}>{s.l}</div>
              <div style={{ fontFamily: CX_MONO, fontSize: 10, color: ink3, marginTop: 2 }}>
                {s.c.toUpperCase()}
              </div>
            </div>
          ))}
        </div>
