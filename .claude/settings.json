{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "MultiEdit",
      "Write",
      "Grep",
      "Glob",
      "LS",
      "TodoRead",
      "TodoWrite",
      "Skill",
      "Agent",
      "Bash",
      "KillShell",
      "TaskCreate",
      "TaskGet",
      "TaskList",
      "TaskOutput",
      "TaskStop",
      "TaskUpdate",
      "Monitor",
      "ToolSearch",
      "WebFetch",
      "WebSearch",
      "NotebookEdit",
      "LSP",
      "PowerShell",
      "Cmd"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/serviceAccount*.json)",
      "Read(**/*secret*)",
      "Bash(rm -rf / *)",
      "Bash(gcloud projects delete*)",
      "Bash(firebase deploy --only firestore:delete*)",
      "WebFetch",
      "WebSearch"
    ]
  },
  "enabledPlugins": {
    "ui-ux-pro-max@ui-ux-pro-max-skill": true,
    "frontend-design@claude-plugins-official": true,
    "firebase@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "context-mode@context-mode": true
  }
}