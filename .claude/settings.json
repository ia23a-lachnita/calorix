{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "MultiEdit",
      "Write",
      "Grep",
      "Glob",
      "LS",
      "TodoRead",
      "TodoWrite",
      "Skill",
      "Agent",
	  "Bash",
	  "Powershell",
	  "Cmd",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(fvm flutter doctor*)",
      "Bash(fvm flutter pub get*)",
      "Bash(fvm flutter analyze*)",
      "Bash(fvm flutter test*)",
      "Bash(fvm flutter run*)",
      "Bash(fvm dart*)",
      "Bash(dart --version*)",
      "Bash(gemini*)",
      "Bash(codex*)",
      "Bash(claude mcp*)",
      "Bash(npx ctx7*)",
      "Bash(npx @google-cloud/gcloud-mcp*)",
      "Bash(npx -y firebase-tools@latest mcp*)",
      "Bash(flutter-mcp-toolkit*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/serviceAccount*.json)",
      "Read(**/*secret*)",
      "Bash(rm -rf / *)",
      "Bash(gcloud projects delete*)",
      "Bash(firebase deploy --only firestore:delete*)",
      "WebFetch",
      "WebSearch"
    ]
  },
  "enabledPlugins": {
    "ui-ux-pro-max@ui-ux-pro-max-skill": true,
    "frontend-design@claude-plugins-official": true,
    "firebase@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "context-mode@context-mode": true
  }
}
